# Copy this file to `.env` and edit the values you actually want to use.
STORAGE_ROOT=./storage
DATABASE_PATH=./storage/app.db
BOOTSTRAP_ADMIN_USERNAME=admin
# Local-dev bootstrap password used by the default launcher flow.
BOOTSTRAP_ADMIN_PASSWORD=change-me-now
SESSION_COOKIE_NAME=rapid_inbox_session
HOST=127.0.0.1
PORT=8000
SMTP_HOST=127.0.0.1
SMTP_PORT=25
MAX_MESSAGE_SIZE_BYTES=52428800
MAX_RECIPIENTS_PER_MESSAGE=20
SMTP_IDLE_TIMEOUT_SECONDS=30
SMTP_MAX_CONCURRENT_CONNECTIONS=0
SMTP_CONNECTION_RATE_LIMIT_COUNT=0
SMTP_CONNECTION_RATE_LIMIT_WINDOW_SECONDS=60
SMTP_CLOSE_AFTER_DATA=true
PARSE_WORKER_COUNT=4
FSYNC_STORAGE_WRITES=false
DISK_WARNING_THRESHOLD_PERCENT=85
ADMIN_TOKEN=dev-admin-token
PUBLIC_API_KEY=public-demo-key
